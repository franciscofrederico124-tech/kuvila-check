<div class="dashboard-grid">
    <!-- Status do Sistema -->
    <div class="card">
        <div class="card-icon"><i class="bi bi-activity"></i></div>
        <div class="card-info">
            <h3>Status do Sistema</h3>
            <p class="card-value">Ativo</p>
        </div>
    </div>

    <div class="card">
        <div class="card-icon orange"><i class="bi bi-thermometer-half"></i></div>
        <div class="card-info">
            <h3>Temp. do Ar</h3>
            <p class="card-value" id="air-temp">.. °C</p>
        </div>
    </div>

    <div class="card">
        <div class="card-icon blue"><i class="bi bi-droplet-half"></i></div>
        <div class="card-info">
            <h3>Humidade do Ar</h3>
            <p class="card-value" id="air-humid">.. %</p>
        </div>
    </div>

    <div class="card">
        <div class="card-icon brown"><i class="bi bi-moisture"></i></div>
        <div class="card-info">
            <h3>Humidade do Solo</h3>
            <p class="card-value" id="soil-humid">-- %</p>
        </div>
    </div>

    <div class="card">
        <div class="card-icon green"><i class="bi bi-wind"></i></div>
        <div class="card-info">
            <h3>Qualidade do Ar</h3>
            <p class="card-value" id="air-quality">..</p>
        </div>
    </div>
</div>
